{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "env": {
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
                "EAS_BUILD_NPM_INSTALL_COMMAND": "npm install --legacy-peer-deps"
            }
        }
    },
    "submit": {
        "production": {}
    }
}